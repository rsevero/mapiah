# --- Area fill patterns, Phase 1 & Phase 3 ---
area water
  l-water-border
endarea
line border -id l-water-border -close on -visibility off
  0.0 2000.0
  150.0 2000.0
  150.0 2150.0
  0.0 2150.0
  0.0 2000.0
endline

